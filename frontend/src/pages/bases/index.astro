---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import BasesSimulator from '../../components/BasesSimulator';
import SimulatorErrorBoundary from '../../components/SimulatorErrorBoundary';

const BADGES = [
  { label: 'Hermite',  bg: 'bg-blue-50',   border: 'border-blue-200',   text: 'text-blue-700',   dot: 'bg-blue-400' },
  { label: 'Legendre', bg: 'bg-indigo-50',  border: 'border-indigo-200', text: 'text-indigo-700', dot: 'bg-indigo-400' },
  { label: 'Sinus',    bg: 'bg-cyan-50',    border: 'border-cyan-200',   text: 'text-cyan-700',   dot: 'bg-cyan-400' },
  { label: 'Overlay',  bg: 'bg-amber-50',   border: 'border-amber-200',  text: 'text-amber-700',  dot: 'bg-amber-400' },
];
---

<ProjectLayout
  title="Bases & Hamiltoniens — Portail Scientifique"
  description="Comparaison des bases fonctionnelles (Hermite, Legendre, Sinus) et des discrétisations hamiltoniennes pour la simulation de l'oscillateur harmonique quantique."
>
  <!-- Page header -->
  <div class="pt-10 pb-8">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      {BADGES.map(({ label, bg, border, text, dot }) => (
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full border font-mono text-xs font-medium ${bg} ${border} ${text}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${dot}`} aria-hidden="true"></span>
          {label}
        </span>
      ))}
    </div>

    <h1 class="font-display font-bold text-3xl sm:text-4xl text-text-primary mb-3 leading-tight">
      Bases &amp; Hamiltoniens
    </h1>

    <p class="font-body text-text-secondary text-base sm:text-lg max-w-2xl leading-relaxed">
      Comparez jusqu'à quatre combinaisons de bases fonctionnelles (Hermite, Legendre, Sinus)
      et de discrétisations hamiltoniennes côte à côte. Visualisez les niveaux d'énergie,
      la convergence et les fonctions propres sur un même graphique.
    </p>
  </div>

  <!-- Divider -->
  <div class="h-px bg-border-subtle mb-8" />

  <!-- Simulator island -->
  <SimulatorErrorBoundary client:load>
    <BasesSimulator client:load />
  </SimulatorErrorBoundary>
</ProjectLayout>
